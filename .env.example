# hackerspace — environment variables
# Copy this file to .env and fill in values you need.

# --- UI Login -------------------------------------------------------
# Protect the web UI with a username/password login form.
# If either var is unset, auth is disabled (no breaking change).
# LOGIN_USER=admin
# LOGIN_PASS=changeme

# --- Authentication -------------------------------------------------
# Option 1 (recommended): OAuth via Claude CLI. Run once:
#   claude auth login
# No env var needed — the server detects OAuth automatically.
#
# Option 2: API key. Uncomment and set. Can also be set from the UI.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Server ---------------------------------------------------------
# Port (default: 3000)
# PORT=3000

# Initial project root (can also be passed as first CLI arg)
# ROOT=/Users/you/Workspace/arcnet

# --- Debug ----------------------------------------------------------
# Verbose logging
# DEBUG=1
